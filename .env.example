# Lakebase (Databricks managed PostgreSQL)
LAKEBASE_HOST=your-lakebase-host.databricks.com
LAKEBASE_PORT=5432
LAKEBASE_DATABASE=uc_catalog_mcp
LAKEBASE_USER=token
LAKEBASE_PASSWORD=your-databricks-token

# Databricks workspace
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-token

# Catalog allowlist (JSON array of "catalog" or "catalog.schema_pattern" strings)
CATALOG_ALLOWLIST=["main", "analytics"]
